        <!-- ─── Central Compute: computeLine17() ─── -->
        <mxCell id="comp" value="computeLine17()&#xa;&#xa;Part I — AMTI:&#xa;line1a = line14 − senior add-back&#xa;line1b = AGI − line1a&#xa;line2a = SALT (if itemizing)&#xa;line2b = −stateLocalRefund&#xa;line2g = PAB interest&#xa;line4 = line1b+2a+2b+2g&#xa;line5 = exemption (phaseout applied)&#xa;line6 = max(0, line4 − line5)&#xa;&#xa;Part II — Tentative min tax:&#xa;Decision: FEITW | AMT_PART_III | DIRECT_RATE&#xa;line7 = tentative min tax&#xa;line9 = line7 − line8 (FTC = 0)&#xa;line10 = line16 + ptcRepay − form4972Tax&#xa;line11 = max(0, line9 − line10)&#xa;&#xa;IRS rule: generate Form 6251 when PAB > 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="150" width="320" height="380" as="geometry" />
        </mxCell>

        <!-- ─── Worksheets (internal) ─── -->
        <mxCell id="ws1" value="computeAmtDirectRate()&#xa;26% up to $239,100 / 28% above&#xa;(MFS split at $119,550)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
