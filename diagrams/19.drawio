<mxfile host="app.diagrams.net">
  <diagram name="Line 19 — Child Tax Credit (Schedule 8812)" id="line19-ctc-schedule8812">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Inputs -->
        <mxCell id="10" value="Form 1040&#xa;line 11b (AGI)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="11" value="Form 2555&#xa;exclusions" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
