          <mxGeometry x="20" y="380" width="140" height="40" as="geometry" />
        </mxCell>

        <!-- Schedule 8812 Part I -->
        <mxCell id="20" value="Schedule 8812 Part I&#xa;&#xa;MAGI = AGI + Form2555 exclusions&#xa;Tentative = CTC×$2200 + ODC×$500&#xa;Phase-out: 5% per $1k over $400k/$200k&#xa;Credit Limit Wkst A = max(0, line18 − Form2441 credit)&#xa;Line 14 = min(tentative−phaseout, Wkst A)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="220" y="60" width="260" height="140" as="geometry" />
        </mxCell>

        <!-- Schedule 8812 Part II-A -->
        <mxCell id="21" value="Schedule 8812 Part II-A&#xa;&#xa;line16a = max(0, tentative−phaseout − line14)&#xa;line16b = $1,700 × qualifying children&#xa;line17 = min(line16a, line16b)&#xa;line18a = wages (line 1z)&#xa;line20 = max(0, (line18a−$2500) × 15%)&#xa;&#xa;If Form2555: line27 = 0&#xa;If &lt;3 children: line27 = min(line17, line20)&#xa;If 3+ children, line20≥line17: line27 = line17&#xa;If 3+ children, line20&lt;line17: line27 = line20 (Part II-B deferred)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="220" y="230" width="260" height="200" as="geometry" />
        </mxCell>

        <!-- Outputs -->
        <mxCell id="30" value="Form 1040 line 19&#xa;(nonrefundable CTC+ODC)&#xa;= Schedule 8812 line 14" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="560" y="100" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="31" value="Form 1040 line 28&#xa;(refundable ACTC)&#xa;= Schedule 8812 line 27" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="560" y="300" width="180" height="60" as="geometry" />
        </mxCell>

