        <!-- Gate 6: reportedOnForm8919 collision guard -->
        <mxCell id='g6' value='employer.reportedOnForm8919 = true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;' vertex='1' parent='1'><mxGeometry x='510' y='820' width='260' height='80' as='geometry'/></mxCell>
