        <mxCell id='e_g1_no' value='No' style='endArrow=block;html=1;exitX=1;exitY=0.5;' edge='1' source='g1' target='null1' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

        <!-- Gate 2: householdWork -->
        <mxCell id='g2' value='householdWork = true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;' vertex='1' parent='1'><mxGeometry x='510' y='240' width='260' height='80' as='geometry'/></mxCell>
        <mxCell id='e_g1_yes' value='Yes' style='endArrow=block;html=1;' edge='1' source='g1' target='g2' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

        <!-- Gate 2 → No: null -->
        <mxCell id='null2' value='line 1b = null&#xa;(no household work)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;' vertex='1' parent='1'><mxGeometry x='840' y='250' width='200' height='60' as='geometry'/></mxCell>
        <mxCell id='e_g2_no' value='No' style='endArrow=block;html=1;exitX=1;exitY=0.5;' edge='1' source='g2' target='null2' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

        <!-- Gate 3: control test -->
        <mxCell id='g3' value='householdEmployeeUnderControlTest = true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;' vertex='1' parent='1'><mxGeometry x='510' y='360' width='260' height='80' as='geometry'/></mxCell>
        <mxCell id='e_g2_yes' value='Yes' style='endArrow=block;html=1;' edge='1' source='g2' target='g3' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

        <!-- Gate 3 → No: blocking flag + Schedule C note -->
        <mxCell id='flag_se' value='Blocking flag:&#xa;HOUSEHOLD_WORK_SELF_EMPLOYMENT_{TAXPAYER|SPOUSE}&#xa;&#xa;Worker appears self-employed.&#xa;→ Route to Schedule C (out of scope)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;' vertex='1' parent='1'><mxGeometry x='840' y='350' width='280' height='100' as='geometry'/></mxCell>
        <mxCell id='e_g3_no' value='No' style='endArrow=block;html=1;exitX=1;exitY=0.5;' edge='1' source='g3' target='flag_se' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

        <!-- Gate 4: receivedW2 -->
        <mxCell id='g4' value='householdReceivedW2 = false?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;' vertex='1' parent='1'><mxGeometry x='510' y='480' width='260' height='80' as='geometry'/></mxCell>
        <mxCell id='e_g3_yes' value='Yes' style='endArrow=block;html=1;' edge='1' source='g3' target='g4' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

        <!-- Gate 4 → No (W-2 received): → line 1a -->
        <mxCell id='line1a' value='Wages belong on line 1a (W-2 box 1)&#xa;line 1b = null for this person' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;' vertex='1' parent='1'><mxGeometry x='840' y='490' width='240' height='60' as='geometry'/></mxCell>
