        <!-- Gate 5: MFS -->
        <mxCell id='g5' value='Filing status = MFS?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;' vertex='1' parent='1'><mxGeometry x='510' y='600' width='260' height='80' as='geometry'/></mxCell>
        <mxCell id='e_g4_yes' value='Yes&#xa;(no W-2)' style='endArrow=block;html=1;' edge='1' source='g4' target='g5' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

        <!-- Gate 5 → Yes: skip spouse -->
        <mxCell id='mfs_note' value='Aggregate taxpayer employers only.&#xa;Spouse employers skipped — MFS filers&#xa;each file their own return.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;' vertex='1' parent='1'><mxGeometry x='840' y='610' width='260' height='70' as='geometry'/></mxCell>
        <mxCell id='e_g5_yes' value='Yes' style='endArrow=block;html=1;exitX=1;exitY=0.5;' edge='1' source='g5' target='mfs_note' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

        <!-- Per-employer loop -->
        <mxCell id='loop' value='For each employer in householdEmployers[]' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;' vertex='1' parent='1'><mxGeometry x='510' y='720' width='260' height='60' as='geometry'/></mxCell>
        <mxCell id='e_g5_no' value='No (MFJ/Single/HOH)' style='endArrow=block;html=1;' edge='1' source='g5' target='loop' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
