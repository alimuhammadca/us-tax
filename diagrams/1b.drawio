        <!-- Output -->
        <mxCell id='out' value='line 1b = roundHalfUp(total)&#xa;→ Form 1040 line 1b&#xa;→ Form 1040 line 1z (total wages)&#xa;→ Form 1040 line 9 (total income)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c84b8;fontSize=12;fontStyle=1;' vertex='1' parent='1'><mxGeometry x='490' y='1040' width='300' height='90' as='geometry'/></mxCell>
