        <!-- Gate 6 → Yes: skip employer (collision guard) -->
        <mxCell id='collision' value='SKIP this employer.&#xa;Collision guard: wages already reported&#xa;on Form 8919 line 1g. Including here&#xa;would double-count in line 1z.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;' vertex='1' parent='1'><mxGeometry x='840' y='820' width='260' height='90' as='geometry'/></mxCell>
