        <!-- Accumulate wages -->
        <mxCell id='accum' value='total += employer.wages' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;' vertex='1' parent='1'><mxGeometry x='510' y='940' width='260' height='60' as='geometry'/></mxCell>
