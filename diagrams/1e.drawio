        <mxCell id='2' value='Inputs (User)&#xa;Childcare expenses form:&#xa;generalQuestions.didReceiveDependentCareBenefits&#xa;generalQuestions.studentOrDisabledDeemedIncome + months&#xa;generalQuestions.studentOrDisabledDeemedIncomeSpouse + months&#xa;generalQuestions.marriedFilingSeparatelyException&#xa;careProviders[].name/address/identifyingNumber&#xa;careProviders[].householdEmployee, amountPaidToProvider&#xa;qualifyingPersons[].name/SSN/disabledOver12/qualifiedExpenses&#xa;dependentCareBenefits.line13Carryover&#xa;dependentCareBenefits.line14ForfeitedOrCarriedForward&#xa;dependentCareBenefits.line16QualifiedExpenses' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='20' width='360' height='250' as='geometry'/></mxCell><mxCell id='3' value='Inputs (Statements/Imports)&#xa;W-2 box 10 dependent care benefits&#xa;W-2 wages by SSN (earned income)&#xa;W-2 total wages fallback' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='290' width='360' height='240' as='geometry'/></mxCell><mxCell id='4' value='Reference/Derived Inputs&#xa;Dependent care benefit limits (MFS/other)&#xa;Expense limits (1 vs 2+ persons)&#xa;Deemed income monthly amounts (250/500)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='550' width='360' height='190' as='geometry'/></mxCell><mxCell id='5' value='Computation&#xa;Form 2441 line12 = sum W-2 box10 benefits&#xa;line15 = line12 + line13 - line14&#xa;line16 = input or sum qualified expenses&#xa;line17 = min(line15, line16)&#xa;line18/19 = earned income (W-2 + deemed income)&#xa;line20 = min(line17, line18, line19)&#xa;line21 = statutory cap&#xa;line26 = max(0, line15 - min(line20, line21))' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='420' y='200' width='380' height='320' as='geometry'/></mxCell><mxCell id='6' value='Outputs&#xa;Form 1040 line 1e&#xa;Form 2441&#xa;Schedule 3 child/dependent care credit' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='830' y='220' width='380' height='280' as='geometry'/></mxCell><mxCell id='7' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='2' target='5'><mxGeometry relative='1' as='geometry'/></mxCell><mxCell id='8' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='3' target='5'><mxGeometry relative='1' as='geometry'/></mxCell><mxCell id='9' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='4' target='5'><mxGeometry relative='1' as='geometry'/></mxCell><mxCell id='10' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='5' target='6'><mxGeometry relative='1' as='geometry'/></mxCell>
