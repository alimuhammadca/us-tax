        <mxCell id='2' value='Inputs (User)&#xa;Form 8919 (per spouse):&#xa;firms[].firmName&#xa;firms[].firmFederalIdNumber&#xa;firms[].reasonCode&#xa;firms[].irsDeterminationDate&#xa;firms[].received1099MiscOrNec&#xa;firms[].wagesNoFicaNotW2' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='20' width='360' height='250' as='geometry'/></mxCell><mxCell id='3' value='Inputs (Statements/Imports)&#xa;W-2 box 3 + 7 SS wages/tips (by SSN)&#xa;W-2 RRTA compensation (by SSN)&#xa;Form 4137 line 10 (per spouse)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='290' width='360' height='240' as='geometry'/></mxCell><mxCell id='4' value='Reference/Derived Inputs&#xa;Social Security wage base' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='550' width='360' height='190' as='geometry'/></mxCell><mxCell id='5' value='Computation&#xa;Line 6 = sum firm wages&#xa;Line 8 = W-2 SS wages/tips + RRTA + Form 4137 line 10&#xa;Line 9 = max(0, line7 - line8)&#xa;Line 10 = min(line6, line9)&#xa;Line 11 = line10 * 0.062&#xa;Line 12 = line6 * 0.0145&#xa;Line 13 = line11 + line12&#xa;Sum taxpayer + spouse' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='420' y='200' width='380' height='320' as='geometry'/></mxCell><mxCell id='6' value='Outputs&#xa;Form 1040 line 1g&#xa;Form 8919 (taxpayer + spouse)&#xa;Schedule 2 line 6' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='830' y='220' width='380' height='280' as='geometry'/></mxCell><mxCell id='7' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='2' target='5'><mxGeometry relative='1' as='geometry'/></mxC