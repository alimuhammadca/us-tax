  <diagram id='2b8d4f7b2d0f4c22' name='Line 2b - Taxable interest'>
    <mxGraphModel dx='1400' dy='900' grid='1' gridSize='10' guides='1' tooltips='1' connect='1' arrows='1' fold='1' page='1' pageScale='1' pageWidth='1200' pageHeight='900' math='0' shadow='0'>
      <root>
        <mxCell id='0'/>
        <mxCell id='1' parent='0'/>
        <mxCell id='2' value='Inputs (User)&#xa;interest-income-taxpayer / interest-income-spouse:&#xa;manualTaxableInterestNotOnStatements&#xa;taxablePortionFrom1099OidBox2Override&#xa;accruedInterestPaidAdjustment&#xa;nomineeInterestAdjustment&#xa;taxableBondPremiumAdjustmentNotInStatements&#xa;treasuryBondPremiumAdjustmentNotInStatements&#xa;oidAcquisitionPremiumAdjustmentNotInStatements&#xa;Taxpayer-only Schedule B controls:&#xa;savingsBondExclusionAmount, claimsSavingsBondExclusionForm8815, foreign account/trust flags' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='20' width='360' height='250' as='geometry'/></mxCell><mxCell id='3' value='Inputs (Statements/Imports)&#xa;1099-INT: box1 + box3, reduced by box11 + box12&#xa;1099-OID: box1 reduced by box6, plus box2 taxable portion&#xa;Per-entry payers become Schedule B interest items&#xa;Statement ownership matched by recipientTIN/SSN' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='290' width='360' height='240' as='geometry'/></mxCell><mxCell id='4' value='Reference/Derived Inputs&#xa;Per-person split: taxpayer vs spouse&#xa;Threshold rule: line2b &gt; 1500&#xa;Additional triggers: accrued/OID/bond-premium adjustments, savings-bond exclusion, foreign account/trust&#xa;Rounding + non-negative guards' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='550' width='360' height='190' as='geometry'/></mxCell><mxCell id='5' value='Computation&#xa;Per person taxable before exclusion =&#xa;sum(1099-INT net taxable interest)&#xa;+ sum(1099-OID net box1)&#xa;+ taxable 1099-OID box2 (override or total box2 - tax-exempt box2 portion)&#xa;+ manual taxable interest&#xa;- accrued/nominee/bond premium/OID acquisition adjustments&#xa;Aggregate taxpayer + spouse&#xa;line2b = taxableBeforeExclusion - Schedule B line3 savings-bond exclusion (floor 0)&#xa;scheduleBRequired = (line2b&gt;1500) OR trigger flags' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='420' y='200' width='380' height='320' as='geometry'/></mxCell><mxCell id='6' value='Outputs&#xa;Form 1040 line 2b (taxable interest)&#xa;Schedule B (when required):&#xa;line2 total interest before exclusion&#xa;line3 savings-bond exclusion&#xa;line4 taxable interest&#xa;Part III foreign account/trust flags&#xa;Schedule B payer item list' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='830' y='220' width='380' height='280' as='geometry'/></mxCell><mxCell id='7' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='2' target='5'><mxGeometry relative='1' as='geometry'/></mxCell><mxCell id='8' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='3' target='5'><mxGeometry relative='1' as='geometry'/></mxCell><mxCell id='9' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='4' target='5'><mxGeometry relative='1' as='geometry'/></mxCell><mxCell id='10' style='endArrow=block;html=1;strokeColor=#6c757d;' edge='1' parent='1' source='5' target='6'><mxGeometry relative='1' as='geometry'/></mxCell>
