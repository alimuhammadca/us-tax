        <mxCell id='2' value='Inputs (Statements)&#xa;SSA-1099 entries: Box 5 netBenefitsAmount&#xa;RRB-1099 entries: Box 5 netSSEBAmount&#xa;Owner assignment by SSN/TIN match (taxpayer/spouse)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='20' y='40' width='360' height='200' as='geometry'/></mxCell>
