        <mxCell id='4' value='Computation&#xa;grossTP = sum(SSA/RRB box 5 for taxpayer owner)&#xa;grossSP = sum(SSA/RRB box 5 for spouse owner)&#xa;Exclude SSI per person: gross = max(0, gross - SSI)&#xa;line6a = roundMoney(grossTP + grossSP)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='420' y='180' width='400' height='220' as='geometry'/></mxCell>
        <mxCell id='5' value='Output&#xa;Form 1040 line 6a (Social security benefits)&#xa;Persisted as income.socialSecurityBenefits&#xa;Feeds line 6b worksheet and line 9 total income path' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#6c757d;fontSize=12;' vertex='1' parent='1'><mxGeometry x='860' y='210' width='320' height='170' as='geometry'/></mxCell>
