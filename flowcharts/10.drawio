    <!-- Compute line 18 -->
    <mxCell id="line18" value="Line 18: Early Withdrawal Penalty&#xa;= manualEntry + sum(1099-INT entries.earlyWithdrawalPenaltyAmount)&#xa;  + sum(1099-OID entries.earlyWithdrawalPenaltyAmount)" style="rectangle;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
