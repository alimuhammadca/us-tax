    <!-- Gate: threshold -->
    <mxCell id="gate_thresh" value="taxableIncomeBeforeQbi&#xa;&gt; threshold?&#xa;($197,300 / $394,600 MFJ)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
