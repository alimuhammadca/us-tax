    </mxCell>

    <!-- PART V SENIOR -->
    <mxCell id="gate_senior" value="Part V — Senior eligible?&#xa;born before Jan 2, 1961&#xa;AND validSSN&#xa;AND (!married OR isMFJ)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
