    <!-- PART II TIPS -->
    <mxCell id="gate_tips" value="Part II — Tips eligible?&#xa;taxpayerReceivedQualifiedTips AND validSSN&#xa;AND (!married OR isMFJ)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
