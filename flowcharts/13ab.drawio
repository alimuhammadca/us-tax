    <mxCell id="e_8995a_no" edge="1" source="gate_8995a_path" target="block_complex" parent="1">
      <mxGeometry relative="1" as="geometry" /><mxCell value="No (blocked)" as="label" />
    </mxCell>

    <mxCell id="form8995a" value="Form 8995-A (above threshold, per activity):&#xa;For each K-1 activity:&#xa;  phaseInPct = (taxInc − threshold) / phaseInRange&#xa;  if SSTB AND above upperThreshold: limited = $0&#xa;  if SSTB AND in phase-in band:&#xa;    applicablePct = 1 − phaseInPct&#xa;    adjQBI = QBI × applicablePct; adjW2/UBIA scaled similarly&#xa;    limited = min(20%×adjQBI, wageUbiaLimit(adjW2, adjUBIA))&#xa;  if non-SSTB AND above upperThreshold:&#xa;    limited = min(tentative, wageUbiaLimit)&#xa;  if non-SSTB AND in phase-in band:&#xa;    reduction = max(0, tentative − wageUbiaLimit) × phaseInPct&#xa;    limited = tentative − reduction&#xa;Sum all activities + REIT/PTP − priorReitPtpCarryforward; apply tiLimit&#xa;→ Form8995A.line39" style="rectangle;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="1060" y="1192" width="380" height="160" as="geometry" />
    </mxCell>
    <mxCell id="e_8995a_yes" edge="1" source="gate_8995a_path" target="form8995a" parent="1">
      <mxGeometry relative="1" as="geometry" /><mxCell value="Yes (K-1 details)" as="label" />
    </mxCell>

    <!-- Merge: line13a result -->
    <mxCell id="line13a_result" value="Form1040.line13a&#xa;(= Form8995.line15 OR Form8995A.line39)&#xa;line13a &gt;= 0 always" style="rectangle;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
