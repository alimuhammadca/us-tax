      <mxGeometry relative="1" as="geometry" /><mxCell value="No" as="label" />
    </mxCell>

    <mxCell id="ot_calc" value="Overtime (line 21):&#xa;raw = W-2 OT + manual (no auto-import)&#xa;cap = $12,500 / $25,000 MFJ&#xa;capped = min(raw, cap)&#xa;excess = max(0, MAGI − $150k/$300k MFJ)&#xa;phaseout = floor(excess/1000) × $100&#xa;line21 = max(0, capped − phaseout)" style="rectangle;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
