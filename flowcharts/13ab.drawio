    <!-- Above threshold: Form 8995-A -->
    <mxCell id="gate_8995a_path" value="Above threshold — valid K-1&#xa;activity details available?&#xa;(blocks: manual, neg K-1, cooperative patron)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="1070" y="1082" width="300" height="75" as="geometry" />
