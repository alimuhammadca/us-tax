    <mxCell id="step13a" value="computeLine13a()&#xa;(only after line 13b is final)" style="rectangle;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
