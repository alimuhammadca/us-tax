      <mxGeometry relative="1" as="geometry" /><mxCell value="Yes" as="label" />
    </mxCell>

    <!-- PART III OVERTIME -->
    <mxCell id="gate_ot" value="Part III — Overtime eligible?&#xa;overtimeReceived AND validSSN&#xa;AND (!married OR isMFJ)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
