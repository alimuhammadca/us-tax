    <!-- PART IV CAR LOAN -->
    <mxCell id="gate_car" value="Part IV — Car loan eligible?&#xa;paidCarLoanInterest = true&#xa;AND vehicle entries exist&#xa;(all filing statuses)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="940" y="370" width="260" height="90" as="geometry" />
