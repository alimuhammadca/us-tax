<mxGraphModel><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="Form 1040 Line 17&#xa;Alternative Minimum Tax (AMT)&#xa;Form 6251 — 2025" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="300" y="20" width="260" height="70" as="geometry"/></mxCell><mxCell id="3" value="Inputs&#xa;line11b (AGI), line14 (deductions)&#xa;Schedule1A.line37 (senior deduction)&#xa;filingStatus, line16 (regular tax)&#xa;pabInterest, stateRefundInIncome&#xa;ptcRepayment, form4972LumpSumTax" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="20" y="20" width="230" height="90" as="geometry"/></mxCell><mxCell id="4" value="Part I — AMTI&#xa;line1a = line14 − Schedule1A.line37&#xa;line1b = line11b − line1a&#xa;line2a = ScheduleA.line7 (itemizing) OR line12e (standard ded.)&#xa;line2b = −stateRefundInIncome&#xa;line2g = pabInterest&#xa;line4 = line1b + line2a + line2b + line2g" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1"><mxGeometry x="270" y="130" width="300" height="110" as="geometry"/></mxCell><mxCell id="5" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="2" target="4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="6" value="G1 FIXED 2026-04-18&#xa;line2a = line12e for non-itemizers&#xa;line2a = scheduleALine7 for itemizers" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="610" y="145" width="180" height="70" as="geometry"/></mxCell><mxCell id="7" value="" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="4" target="6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="8" value="Exemption + Phaseout (line5/6)&#xa;Single/HOH: $88,100 (phaseout $626,350)&#xa;MFJ/QSS: $137,000 (phaseout $1,252,700)&#xa;MFS: $68,500 (phaseout $626,350)&#xa;reduction = max(0, line4−threshold) ×