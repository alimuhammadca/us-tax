  <diagram id='line1a-computation' name='Line 1a Computation Flowchart'>
    <mxGraphModel dx='1400' dy='900' grid='1' gridSize='10' guides='1' tooltips='1' connect='1' arrows='1' fold='1' page='1' pageScale='1' pageWidth='1400' pageHeight='2600' math='0' shadow='0'>
      <root>
        <mxCell id='0'/>
        <mxCell id='1' parent='0'/>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LEGEND -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id='leg0' value='Legend' style='text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;fontStyle=1;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='40' width='100' height='30' as='geometry'/>
        </mxCell>
        <mxCell id='leg1' value='Start / End' style='ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='80' width='120' height='40' as='geometry'/>
        </mxCell>
        <mxCell id='leg2' value='Process / Action' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='130' width='120' height='40' as='geometry'/>
        </mxCell>
        <mxCell id='leg3' value='Decision' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='180' width='120' height='50' as='geometry'/>
        </mxCell>
        <mxCell id='leg4' value='Output / Result' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='240' width='120' height='40' as='geometry'/>
        </mxCell>
        <mxCell id='leg5' value='Blocking Flag' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#842029;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='290' width='120' height='40' as='geometry'/>
        </mxCell>
        <mxCell id='leg6' value='Input Data' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='340' width='120' height='40' as='geometry'/>
        </mxCell>
        <mxCell id='leg7' value='Implemented&#xa;(completed)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d1e7dd;strokeColor=#0f5132;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='390' width='120' height='40' as='geometry'/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ABBREVIATION KEY -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id='abbr' value='Abbreviations&#xa;&#xa;NQDC = Nonqualified Deferred Compensation&#xa;         (also covers non-governmental Section 457 plans)&#xa;SSN  = Social Security Number&#xa;MFJ  = Married Filing Jointly&#xa;MFS  = Married Filing Separately&#xa;W-2  = IRS Form W-2 (Wage and Tax Statement)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f4ff;strokeColor=#3b5bdb;fontSize=11;align=left;spacingLeft=8;' vertex='1' parent='1'>
          <mxGeometry x='1060' y='450' width='260' height='150' as='geometry'/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MAIN FLOW — centre column x≈350 -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- START -->
        <mxCell id='n01' value='START&#xa;computeLine1aWages()' style='ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;' vertex='1' parent='1'>
          <mxGeometry x='250' y='40' width='220' height='55' as='geometry'/>
        </mxCell>

        <!-- INIT ACCUMULATORS -->
        <mxCell id='n02' value='Initialise accumulators&#xa;line1aTotal = 0&#xa;nqdcSum = 0   (Nonqualified Deferred Comp / Sec 457)&#xa;inmateSum = 0&#xa;flags = []' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='230' y='120' width='260' height='80' as='geometry'/>
        </mxCell>

        <!-- LOAD W-2 ENTRIES -->
        <mxCell id='n03' value='Load all W-2 statement entries&#xa;listEntriesWithData(uid, "w-2")' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='250' y='225' width='220' height='55' as='geometry'/>
        </mxCell>

        <!-- LOOP: MORE W-2s? -->
        <mxCell id='n04' value='More W-2&#xa;entries?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='265' y='305' width='190' height='70' as='geometry'/>
        </mxCell>

        <!-- STATUTORY EMPLOYEE? -->
        <mxCell id='n05' value='W-2 box 13&#xa;Statutory employee&#xa;flag == true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='265' y='410' width='190' height='75' as='geometry'/>
        </mxCell>

        <!-- EMIT STATUTORY FLAG -->
        <mxCell id='n06' value='Emit flag&#xa;STATUTORY_EMPLOYEE_W2_OUT_OF_SCOPE&#xa;(one per statutory W-2 found)&#xa;&#xa;Statutory employees report wages on&#xa;Schedule C, not line 1a.&#xa;Schedule C is out of scope.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#842029;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='530' y='405' width='260' height='90' as='geometry'/>
        </mxCell>

        <!-- SKIP W-2 (contribution = 0) -->
        <mxCell id='n07' value='contribution = 0&#xa;skip to next W-2' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='530' y='515' width='260' height='45' as='geometry'/>
        </mxCell>

        <!-- SET ELIGIBLE = BOX1 -->
        <mxCell id='n08' value='eligible = w2.wagesTipsOtherCompAmount&#xa;(box 1 — wages, tips, other comp)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='240' y='525' width='240' height='50' as='geometry'/>
        </mxCell>

        <!-- BOX 11 NQDC > 0? -->
        <mxCell id='n09' value='nonqualifiedPlansAmount&#xa;(box 11 — Nonqualified Deferred&#xa;Compensation / Non-governmental&#xa;Section 457) &gt; 0?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='250' y='605' width='220' height='90' as='geometry'/>
        </mxCell>

        <!-- SUBTRACT NQDC -->
        <mxCell id='n10' value='eligible = subtractNonNegative(eligible, box11)&#xa;nqdcSum += box11&#xa;[Nonqualified Deferred Comp / Sec 457&#xa; → will flow to Schedule 1 line 8t]' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='530' y='615' width='260' height='70' as='geometry'/>
        </mxCell>

        <!-- INMATE WAGES? -->
        <mxCell id='n11' value='hasUncommonW2Situations == true&#xa;AND hasInmateWages == true?&#xa;[read from employment personal form]' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='250' y='730' width='220' height='75' as='geometry'/>
        </mxCell>

        <!-- SUBTRACT INMATE WAGES -->
        <mxCell id='n12' value='eligible = subtractNonNegative(eligible, inmateWagesAmount)&#xa;inmateSum += inmateWagesAmount&#xa;[Inmate wages → Schedule 1 line 8u]' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='530' y='735' width='260' height='65' as='geometry'/>
        </mxCell>

        <!-- ADD TO TOTAL -->
        <mxCell id='n13' value='line1aTotal += max(0, eligible)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='250' y='845' width='220' height='45' as='geometry'/>
        </mxCell>

        <!-- ── AFTER LOOP ── -->

        <!-- FORM 4852 SUBSTITUTE W-2 (IMPLEMENTED) -->
        <mxCell id='n14a' value='Add Form 4852 (Substitute W-2) wages&#xa;extractForm4852Line1aWages(form4852-taxpayer)&#xa;  if needsForm4852 == true&#xa;  AND substituteFormType == "w2" (not 1099-R)&#xa;  → line1aTotal += line7aWagesTipsOtherCompensation&#xa;&#xa;extractForm4852Line1aWages(form4852-spouse)&#xa;  same logic; skipped on MFS returns&#xa;&#xa;Status: IMPLEMENTED (2026-04-09)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d1e7dd;strokeColor=#0f5132;fontSize=11;align=left;spacingLeft=8;' vertex='1' parent='1'>
          <mxGeometry x='230' y='920' width='280' height='155' as='geometry'/>
        </mxCell>

        <!-- VALIDATION GATE: EMPLOYMENT INCOME CHECK -->
        <mxCell id='n14' value='Load employment-income-taxpayer&#xa;(and spouse if MFJ)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='250' y='1105' width='220' height='55' as='geometry'/>
        </mxCell>

        <!-- TAXPAYER: HAS EMPLOYMENT INCOME? -->
        <mxCell id='n15' value='Taxpayer:&#xa;hasEmploymentIncome == true&#xa;AND householdWork != true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='255' y='1190' width='210' height='80' as='geometry'/>
        </mxCell>

        <!-- TAXPAYER: W-2 OR FORM 4852 PRESENT? -->
        <mxCell id='n16' value='W-2 with taxpayer SSN&#xa;(Social Security Number) exists?&#xa;OR Form 4852 W-2 substitute&#xa;(form4852-taxpayer) present?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='245' y='1305' width='230' height='90' as='geometry'/>
        </mxCell>

        <!-- MISSING W-2 TAXPAYER FLAG -->
        <mxCell id='n17' value='Emit flag&#xa;MISSING_W2_EMPLOYMENT_INCOME_TAXPAYER&#xa;&#xa;Suppressed if Form 4852 W-2&#xa;substitute is present.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#842029;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='530' y='1315' width='250' height='70' as='geometry'/>
        </mxCell>

        <!-- SPOUSE: HAS EMPLOYMENT INCOME? (MFJ only) -->
        <mxCell id='n18' value='Spouse (MFJ only):&#xa;hasEmploymentIncome == true&#xa;AND householdWork != true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='255' y='1430' width='210' height='80' as='geometry'/>
        </mxCell>

        <!-- SPOUSE: W-2 OR FORM 4852 PRESENT? -->
        <mxCell id='n19' value='W-2 with spouse SSN&#xa;(Social Security Number) exists?&#xa;OR Form 4852 W-2 substitute&#xa;(form4852-spouse) present?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='245' y='1545' width='230' height='90' as='geometry'/>
        </mxCell>

        <!-- MISSING W-2 SPOUSE FLAG -->
        <mxCell id='n20' value='Emit flag&#xa;MISSING_W2_EMPLOYMENT_INCOME_SPOUSE&#xa;&#xa;Suppressed if Form 4852 W-2&#xa;substitute is present.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#842029;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='530' y='1555' width='250' height='70' as='geometry'/>
        </mxCell>

        <!-- ── SCHEDULE 1 AGGREGATION ── -->
        <mxCell id='n21' value='Load other-incomes-taxpayer&#xa;and other-incomes-spouse forms&#xa;(non-W-2 NQDC and inmate amounts)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='250' y='1665' width='220' height='65' as='geometry'/>
        </mxCell>

        <!-- COMPUTE LINE 8t -->
        <mxCell id='n22' value='Schedule 1 line 8t&#xa;(Nonqualified Deferred Compensation&#xa; / Non-governmental Section 457):&#xa;line8t =&#xa;  nqdcSum  (from W-2 box 11)&#xa;  + otherIncomesTaxpayer.otherIncomeNonqualifiedDeferredComp8t&#xa;  + otherIncomesSpouse.otherIncomeNonqualifiedDeferredComp8t' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;' vertex='1' parent='1'>
          <mxGeometry x='230' y='1755' width='280' height='100' as='geometry'/>
        </mxCell>

        <!-- COMPUTE LINE 8u -->
        <mxCell id='n23' value='Schedule 1 line 8u&#xa;(Wages earned while incarcerated):&#xa;line8u =&#xa;  inmateSum  (from W-2 entries)&#xa;  + otherIncomesTaxpayer.otherIncomeWagesWhileIncarcerated8u&#xa;  + otherIncomesSpouse.otherIncomeWagesWhileIncarcerated8u' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;' vertex='1' parent='1'>
          <mxGeometry x='230' y='1875' width='280' height='100' as='geometry'/>
        </mxCell>

        <!-- OUTPUTS -->
        <mxCell id='n24' value='OUTPUT&#xa;form1040.income.wages = line1aTotal&#xa;(Form 1040 line 1a)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;' vertex='1' parent='1'>
          <mxGeometry x='250' y='1995' width='220' height='60' as='geometry'/>
        </mxCell>

        <mxCell id='n25' value='OUTPUT&#xa;schedule1.additionalIncome&#xa;.otherIncomeNonqualifiedDeferredComp&#xa;= line8t  (null if zero)&#xa;(Schedule 1 line 8t —&#xa; Nonqualified Deferred Comp / Sec 457)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;' vertex='1' parent='1'>
          <mxGeometry x='250' y='2080' width='220' height='90' as='geometry'/>
        </mxCell>

        <mxCell id='n26' value='OUTPUT&#xa;schedule1.additionalIncome&#xa;.otherIncomeWagesWhileIncarcerated&#xa;= line8u  (null if zero)&#xa;(Schedule 1 line 8u —&#xa; Wages while incarcerated)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;' vertex='1' parent='1'>
          <mxGeometry x='250' y='2190' width='220' height='90' as='geometry'/>
        </mxCell>

        <!-- INVARIANT CHECK NOTE -->
        <mxCell id='n27' value='Invariant (no double-counting):&#xa;line1aTotal + nqdcSum + inmateSum&#xa;== Σ box 1 (non-statutory W-2s)&#xa;&#xa;wages + 8t + 8u = original W-2 box 1 total' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=2;' vertex='1' parent='1'>
          <mxGeometry x='530' y='2080' width='260' height='85' as='geometry'/>
        </mxCell>

        <!-- END -->
        <mxCell id='n29' value='END' style='ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;' vertex='1' parent='1'>
          <mxGeometry x='290' y='2305' width='140' height='50' as='geometry'/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- EDGES -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- n01 → n02 -->
        <mxCell id='e01' style='endArrow=block;html=1;' edge='1' parent='1' source='n01' target='n02'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n02 → n03 -->
        <mxCell id='e02' style='endArrow=block;html=1;' edge='1' parent='1' source='n02' target='n03'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n03 → n04 -->
        <mxCell id='e03' style='endArrow=block;html=1;' edge='1' parent='1' source='n03' target='n04'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n04 YES → n05 (next W-2) -->
        <mxCell id='e04' value='YES&#xa;(next W-2)' style='endArrow=block;html=1;' edge='1' parent='1' source='n04' target='n05'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n04 NO → n14a (all W-2s done — add Form 4852) -->
        <mxCell id='e05' value='NO (all W-2s done)' style='endArrow=block;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;' edge='1' parent='1' source='n04' target='n14a'>
          <mxGeometry relative='1' as='geometry'>
            <Array as='points'>
              <mxPoint x='840' y='340'/>
              <mxPoint x='840' y='997'/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- n05 YES → n06 -->
        <mxCell id='e06' value='YES' style='endArrow=block;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;' edge='1' parent='1' source='n05' target='n06'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n06 → n07 -->
        <mxCell id='e07' style='endArrow=block;html=1;' edge='1' parent='1' source='n06' target='n07'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n07 → n04 (loop back) -->
        <mxCell id='e08' value='back to loop' style='endArrow=block;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;curved=1;' edge='1' parent='1' source='n07' target='n04'>
          <mxGeometry relative='1' as='geometry'>
            <Array as='points'>
              <mxPoint x='880' y='537'/>
              <mxPoint x='880' y='340'/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- n05 NO → n08 -->
        <mxCell id='e09' value='NO' style='endArrow=block;html=1;' edge='1' parent='1' source='n05' target='n08'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n08 → n09 -->
        <mxCell id='e10' style='endArrow=block;html=1;' edge='1' parent='1' source='n08' target='n09'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n09 YES → n10 -->
        <mxCell id='e11' value='YES' style='endArrow=block;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;' edge='1' parent='1' source='n09' target='n10'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n10 → n11 (rejoin) -->
        <mxCell id='e12' style='endArrow=block;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;' edge='1' parent='1' source='n10' target='n11'>
          <mxGeometry relative='1' as='geometry'>
            <Array as='points'>
              <mxPoint x='530' y='715'/>
              <mxPoint x='470' y='730'/>
