        <!-- n09 NO → n11 -->
        <mxCell id='e13' value='NO' style='endArrow=block;html=1;' edge='1' parent='1' source='n09' target='n11'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n11 YES → n12 -->
        <mxCell id='e14' value='YES' style='endArrow=block;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;' edge='1' parent='1' source='n11' target='n12'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n12 → n13 (rejoin) -->
        <mxCell id='e15' style='endArrow=block;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;' edge='1' parent='1' source='n12' target='n13'>
          <mxGeometry relative='1' as='geometry'>
            <Array as='points'>
              <mxPoint x='530' y='830'/>
              <mxPoint x='470' y='867'/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- n11 NO → n13 -->
        <mxCell id='e16' value='NO' style='endArrow=block;html=1;' edge='1' parent='1' source='n11' target='n13'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n13 → n04 (loop back) -->
        <mxCell id='e17' value='next W-2' style='endArrow=block;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;' edge='1' parent='1' source='n13' target='n04'>
          <mxGeometry relative='1' as='geometry'>
