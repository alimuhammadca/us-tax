        </mxCell>

        <!-- n14 → n15 -->
        <mxCell id='e18' style='endArrow=block;html=1;' edge='1' parent='1' source='n14' target='n15'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n15 YES → n16 -->
        <mxCell id='e19' value='YES' style='endArrow=block;html=1;' edge='1' parent='1' source='n15' target='n16'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- n15 NO → n18 -->
        <mxCell id='e20' value='NO' style='endArrow=block;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;' edge='1' parent='1' source='n15' target='n18'>
          <mxGeometry relative='1' as='geometry'>
