    <mxCell id='e05' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n04' target='n05' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e06' value='YES' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n05' target='n06' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e07' value='NO' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n05' target='n07' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e08' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n07' target='n08' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e09' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n08' target='n09' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e10' value='YES' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n09' target='n10' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e11' value='YES' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n10' target='n11' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e12' value='NO' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n10' target='n12' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e13' value='NO' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n09' target='n13' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e14' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n11' target='n14' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e15' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n12' target='n14' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e16' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n13' target='n14' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
