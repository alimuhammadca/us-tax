<mxGraphModel dx='1400' dy='900' grid='1' gridSize='10' guides='1' tooltips='1' connect='1' arrows='1' fold='1' page='1' pageScale='1' pageWidth='1654' pageHeight='1169' math='0' shadow='0'>
  <root>
    <mxCell id='0'/>
    <mxCell id='1' parent='0'/>

    <!-- ══ TITLE ══ -->
    <mxCell id='title' value='Form 1040 Line 1f — Taxable Adoption Benefits (Form 8839 Part III)&#xa;Method: computeAdoptionBenefits() in TaxReturnComputeService' style='text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1' vertex='1' parent='1'>
      <mxGeometry x='150' y='20' width='960' height='50' as='geometry'/>
    </mxCell>

    <!-- ══ START ══ -->
    <mxCell id='n01' value='START: computeAdoptionBenefits(data, w2Entries, filingStatus, mfsException, flags)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;' vertex='1' parent='1'>
      <mxGeometry x='310' y='85' width='560' height='45' as='geometry'/>
    </mxCell>

    <!-- ══ GATE 1: hasAnyAdoptionInputs ══ -->
    <mxCell id='n02' value='hasAnyAdoptionInputs(data)?&#xa;[W-2 code T total &gt; 0  OR  any child-level&#xa;benefit or expense field is non-null/non-zero]' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
      <mxGeometry x='445' y='152' width='290' height='80' as='geometry'/>
    </mxCell>
    <mxCell id='n02x' value='return null&#xa;[no adoption data — line 1f = null]' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#842029;fontSize=11;' vertex='1' parent='1'>
      <mxGeometry x='790' y='172' width='255' height='45' as='geometry'/>
    </mxCell>

    <!-- ══ READ W-2 CODE T ══ -->
    <mxCell id='n03' value='Aggregate W-2 box 12 code T across all W-2 entries:&#xa;  w2AdoptionTotal = Σ box12Entries[code=="T"].box12Amount&#xa;&#xa;Read from personal form adoption-expenses:&#xa;  children.entries[]   (up to 6 per return)&#xa;  employerBenefitsPartIII.priorYearEmployerBenefitsByChild&#xa;  employerBenefitsPartIII.currentYearBenefitsAllocation&#xa;  imports.magiForAdoptionBenefitsExclusion   (MAGI — backend-computed import)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='290' y='262' width='600' height='125' as='geometry'/>
    </mxCell>

    <!-- ══ GATE 2: MFS without exception ══ -->
    <mxCell id='n04' value='filingStatus == MFS  AND&#xa;mfsException == false?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
      <mxGeometry x='445' y='415' width='290' height='72' as='geometry'/>
    </mxCell>
    <mxCell id='n04y' value='★ MFS without exception — exclusion disallowed (IRC §137(f)):&#xa;  emit ADOPTION_BENEFITS_MFS_EXCLUSION_DISALLOWED [non-blocking]&#xa;  line 1f = w2AdoptionTotal   [full W-2 code T amount is taxable]&#xa;  return form8839 with part3Line31TaxableBenefits = w2AdoptionTotal' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='790' y='418' width='350' height='70' as='geometry'/>
    </mxCell>

    <!-- ══ GATE 3: >6 children ══ -->
    <mxCell id='n05' value='children.entries.length &gt; 6?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
      <mxGeometry x='455' y='519' width='270' height='65' as='geometry'/>
    </mxCell>
    <mxCell id='n05y' value='emit ADOPTION_BENEFITS_TOO_MANY_CHILDREN [non-blocking]&#xa;[computation continues on first 6 children;&#xa; filer must attach a separate Form 8839 for extras]' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='790' y='524' width='340' height='55' as='geometry'/>
    </mxCell>

    <!-- ══ PART III HEADER ══ -->
    <mxCell id='ph3hdr' value='PART III — Per-Child Computation (lines 19–24, 28–29)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1' vertex='1' parent='1'>
      <mxGeometry x='310' y='620' width='560' height='28' as='geometry'/>
    </mxCell>

    <!-- ══ PER-CHILD LOOP ══ -->
    <mxCell id='n06' value='For each child i (0-indexed, up to 6):&#xa;&#xa;  L19[i] = 17,280   (2025 per-child exclusion max — from ReferenceData)&#xa;  L20[i] = priorYearEmployerBenefitsByChild["child" + (i+1) + "PriorYearBenefits"]  ?? 0&#xa;  L21[i] = L19[i] − L20[i]   (remaining exclusion available for this child)&#xa;  L22[i] = currentYearBenefitsAllocation["child" + (i+1) + "Benefits2025"]  ?? 0&#xa;&#xa;  Special-needs rule (IRC §137(a)(3)):&#xa;    if child.hasSpecialNeeds == true  AND  child.adoptionFinal2025OrEarlier == true:&#xa;      L24[i] = L21[i]   [full remaining exclusion, regardless of L22[i]]&#xa;    else:&#xa;      L24[i] = min(L21[i], L22[i])   [limited to actual current-year benefits]&#xa;&#xa;  Foreign-child finality rule:&#xa;    if child.isForeignChild == true  AND  child.adoptionFinal2025OrEarlier == false:&#xa;      → UI blocks save; no compute path needed here&#xa;      [foreign adoptions not yet final: benefits not yet excludable]' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='260' y='662' width='660' height='270' as='geometry'/>
    </mxCell>

    <!-- ══ PART III TOTALS HEADER ══ -->
    <mxCell id='ph3tot' value='PART III — Return-Level Totals and MAGI Phaseout (lines 23, 25–31)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1' vertex='1' parent='1'>
      <mxGeometry x='310' y='968' width='560' height='28' as='geometry'/>
    </mxCell>

    <!-- ══ LINE 23 ══ -->
    <mxCell id='n07' value='L23 = Σ L22[i]   (total current-year employer-provided adoption benefits across all children)&#xa;      [must equal w2AdoptionTotal for the save to be permitted]' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='270' y='1010' width='640' height='52' as='geometry'/>
    </mxCell>

    <!-- ══ GATE 4: MAGI available ══ -->
    <mxCell id='n08' value='MAGI (imports.magiFor&#xa;AdoptionBenefitsExclusion)&#xa;available?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
      <mxGeometry x='440' y='1086' width='300' height='72' as='geometry'/>
    </mxCell>
    <mxCell id='n08x' value='L25 = null&#xa;phaseout fraction = 0&#xa;[MAGI not yet available; no phaseout applied;&#xa;compute continues with zero reduction]' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;' vertex='1' parent='1'>
      <mxGeometry x='790' y='1093' width='275' height='58' as='geometry'/>
    </mxCell>

    <!-- ══ MAGI PHASEOUT ══ -->
    <mxCell id='n09' value='L25 = MAGI&#xa;&#xa;If L25 ≤ 259,190:&#xa;  L26 = 0  (no phaseout)&#xa;  L27 = 0  (phaseout fraction = 0)&#xa;&#xa;If L25 &gt; 259,190:&#xa;  L26 = L25 − 259,190&#xa;  L27 = min(1.0000, L26 / 40,000)   (phaseout fraction; 4 decimal places)&#xa;&#xa;For each child i:&#xa;  L28[i] = roundMoney(L24[i] × L27)   (phaseout reduction per child)&#xa;  L29[i] = L24[i] − L28[i]            (excluded benefits for this child)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='260' y='1186' width='660' height='195' as='geometry'/>
    </mxCell>

    <!-- ══ LINES 30–31 ══ -->
    <mxCell id='n10' value='L30 = Σ L29[i]   (total excluded benefits across all children)&#xa;L31 = L23 − L30   (taxable benefits; may be negative — see note below)&#xa;&#xa;★ Negative L31 is valid: arises when prior-year benefits become retroactively excludable&#xa;  in the finality year of a foreign adoption. L23 &lt; L30 → subtract L23 from L30, enter negative.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='260' y='1405' width='660' height='95' as='geometry'/>
    </mxCell>

    <!-- ══ OUTPUT ══ -->
    <mxCell id='n11' value='Output:&#xa;  form1040.income.adoptionBenefits = L31   [Form 1040 line 1f]&#xa;  form8839.part3Line23TotalBenefits = L23&#xa;  form8839.part3Line31TaxableBenefits = L31&#xa;  form8839.children[i].part3Line22CurrentYearBenefits = L22[i]&#xa;  form8839.children[i].part3Line24ExcludableBeforePhaseout = L24[i]&#xa;  form8839.children[i].part3Line28PhaseoutReduction = L28[i]&#xa;  form8839.children[i].part3Line29ExcludedBenefits = L29[i]&#xa;  form8839.part3Line25Magi = L25  (null if MAGI unavailable)&#xa;  form8839.part3Line27PhaseoutFraction = L27' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='260' y='1520' width='660' height='160' as='geometry'/>
    </mxCell>

    <!-- ══ DOWNSTREAM ══ -->
    <mxCell id='n12' value='Downstream wiring:&#xa;→ form1040.income.adoptionBenefits (line 1f)  contributes to line 1z  →  line 9 (total income)&#xa;→ form8839 output persisted to Firestore with full per-child breakdown&#xa;→ Shell sidebar "Form 8839" item rendered conditionally: if (computation?.form8839) { items.push(...) }&#xa;→ form-tax-return-8839 displays Part III per-child and return-level totals + PDF export (f8839 template)&#xa;   PDF: children 1–3 on main page; children 4–6 on overflow page appended via pdf-lib copyPages()' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d1e7dd;strokeColor=#0f5132;fontSize=11;align=left;spacingLeft=6;' vertex='1' parent='1'>
      <mxGeometry x='240' y='1698' width='700' height='120' as='geometry'/>
    </mxCell>

    <!-- ══ EDGES ══ -->
    <mxCell id='e01' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n01' target='n02' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e02' value='NO' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n02' target='n02x' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e03' value='YES' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n02' target='n03' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e04' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n03' target='n04' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e05' value='YES' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n04' target='n04y' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e06' value='NO' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n04' target='n05' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e07' value='YES' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n05' target='n05y' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e08' value='NO (continue)' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n05' target='ph3hdr' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <!-- Flag emitted but computation continues -->
    <mxCell id='e08b' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n05y' target='ph3hdr' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e09' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='ph3hdr' target='n06' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e10' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n06' target='ph3tot' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e11' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='ph3tot' target='n07' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e12' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n07' target='n08' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e13' value='NO' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n08' target='n08x' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e14' value='YES' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n08' target='n09' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <!-- Both MAGI paths converge at lines 30-31 -->
    <mxCell id='e15' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n08x' target='n10' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e16' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n09' target='n10' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e17' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n10' target='n11' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
    <mxCell id='e18' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n11' target='n12' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>

  </root>
</mxGraphModel>
