<!-- ===== GAPS BOX ===== -->
<mxCell id="gapsBox" value="All gaps fixed 2026-04-19&#xa;&#xa;G1 FIXED — computeLine26EstimatedTax() now reads both taxpayer and spouse forms for MFJ.&#xa;G2 FIXED — 4 new unit tests: MFJ both forms, MFJ spouse-only, MFJ null taxpayer form, MFS isolation.&#xa;G3 FIXED — 4 new E2E tests: MFJ combined, MFJ spouse-only, MFS isolation, divorceFormerSpouseSSN.&#xa;G4 FIXED — taxpayerForm==null no longer causes early return; MFJ spouse-only payments preserved.&#xa;G5 FIXED — divorceFormerSpouseSSN E2E round-trip test added (annotation-only field verified)." style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;fontSize=9;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="280" y="560" width="500" height="125" as="geometry"/></mxCell>

