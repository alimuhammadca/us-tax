<mxCell id="leg1" value="LEGEND" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="58" width="80" height="20" as="geometry"/></mxCell>
<mxCell id="leg2" value="Input (personal form)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="78" width="120" height="22" as="geometry"/></mxCell>
<mxCell id="leg3" value="Computation" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1"><mxGeometry x="180" y="78" width="110" height="22" as="geometry"/></mxCell>
<mxCell id="leg4" value="Output / consumer" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1"><mxGeometry x="300" y="78" width="120" height="22" as="geometry"/></mxCell>
<mxCell id="leg5" value="Gap (fixed)" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1"><mxGeometry x="430" y="78" width="80" height="22" as="geometry"/></mxCell>
<mxCell id="leg6" value="Deferred / OOS" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1"><mxGeometry x="520" y="78" width="100" height="22" as="geometry"/></mxCell>

<!-- ===== INPUTS — LEFT COLUMN ===== -->

<!-- Screening gate -->
<mxCell id="gate" value="Screening gate&#xa;earned-income-credit-taxpayer&#xa;claimsEIC = true (required)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="130" width="180" height="50" as="geometry"/></mxCell>

<!-- Hard disqualifiers -->
<mxCell id="disq" value="Hard disqualifiers&#xa;hasForm2555 = true → null&#xa;isNonresidentAlien = true → null&#xa;eicPreviouslyDenied → Form 8862 gate&#xa;MFS filing status:&#xa;  qualifiesForMfsSeparatedSpouseEicException&#xa;  = false → null&#xa;  = true → use Single thresholds [G8]" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="195" width="180" height="100" as="geometry"/></mxCell>

<!-- Earned income inputs -->
<mxCell id="earnedIn" value="Earned income inputs&#xa;W-2 wagesTipsOtherCompAmount (box 1)&#xa;  [filtered by taxpayer SSN; null=MFJ]&#xa;otherEarnedIncome (personal form)&#xa;combatPay (W-2 box 12Q, if elected)&#xa;[MFJ: + spouse earned income / combat]" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="310" width="180" height="90" as="geometry"/></mxCell>

<!-- Investment income gate -->
<mxCell id="investGate" value="Investment income ceiling&#xa;taxExemptInterest (2a)&#xa;+ taxableInterest (2b)&#xa;+ ordinaryDividends (3b)&#xa;+ max(0, capitalGainLoss 7a)&#xa;If total &gt; $11,950 → null" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="415" width="180" height="90" as="geometry"/></mxCell>

<!-- Qualifying children -->
<mxCell id="qChildren" value="Qualifying children [G2, G3, G7 fixed]&#xa;eicQualifyingChildren array — child counts if:&#xa;  (a) childSSN present&#xa;  (b) relationship in EIC_QUALIFYING_RELATIONSHIPS [G3]&#xa;  (c) childFiledJointReturn ≠ true [G2]&#xa;  (d) monthsLivedWithTaxpayer &gt; 6&#xa;  (e) isPermanentlyDisabled = true&#xa;      OR ageAtYearEnd &lt; 19&#xa;      OR (age 19-23 AND isFullTimeStudent) [G7]" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="520" width="180" height="120" as="geometry"/></mxCell>

<!-- Childless age test -->
<mxCell id="ageTest" value="Childless age test&#xa;(only if numChildren == 0&#xa; and NOT MFS exception)&#xa;you.dateOfBirth → age at year-end&#xa;age &lt; 25 OR age &gt; 64 → null" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="655" width="180" height="70" as="geometry"/></mxCell>

<!-- Spouse form -->
<mxCell id="spouseForm" value="MFJ supplemental&#xa;earned-income-credit-spouse&#xa;spouseOtherEarnedIncome&#xa;spouseElectNontaxableCombatPay" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="740" width="180" height="65" as="geometry"/></mxCell>

<!-- AGI -->
<mxCell id="agi" value="AGI from line 11b&#xa;form1040.adjustments&#xa;  .line11bAmountFromLine11a..." style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1"><mxGeometry x="50" y="820" width="180" height="50" as="geometry"/></mxCell>

<!-- ===== COMPUTATION ===== -->

<mxCell id="calc27a" value="computeLine27aEIC()&#xa;TaxReturnComputeService.java&#xa;&#xa;1. Screening gate check (claimsEIC)&#xa;2. Hard disqualifier gates&#xa;   hasForm2555 / isNonresidentAlien / Form8862&#xa;3. MFS check [G8 fixed]:&#xa;   exception=false → null&#xa;   exception=true → filingStatusStr=&quot;Single&quot;&#xa;4. Earned income aggregation&#xa;5. Investment income gate (&gt;$11,950 → null)&#xa;6. Count qualifying children [G2,G3,G7]:&#xa;   SSN + relationship + !jointReturn&#xa;   + months&gt;6 + (age&lt;19 OR student19-23 OR disabled)&#xa;   MFS exception + 0 children → null&#xa;7. Childless age test (25–64)&#xa;8. Dual EIC table lookup&#xa;   creditFromEarned = eicTableLookup(earned, status, n)&#xa;   creditFromAGI = eicTableLookup(agi, status, n)&#xa;   credit = min(creditFromEarned, creditFromAGI)&#xa;9. FLOOR rounding; null if ≤ 0" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1"><mxGeometry x="285" y="310" width="240" height="280" as="geometry"/></mxCell>

<!-- eicTableLookup computation box -->
<mxCell id="eicTable" value="eicTableLookup()&#xa;&#xa;if income ≤ phaseInEnd:&#xa;  credit = income × phaseInRate&#xa;elif income ≤ phaseoutStart:&#xa;  credit = maxCredit&#xa;elif income &lt; phaseoutEnd:&#xa;  credit = maxCredit − (income−phaseoutStart)×rate&#xa;else: credit = 0&#xa;return FLOOR(max(0, credit))&#xa;&#xa;MFS exception filers use Single thresholds [G8]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1"><mxGeometry x="285" y="630" width="240" height="155" as="geometry"/></mxCell>

<!-- Edges: inputs → computation -->
<mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="gate" target="calc27a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="disq" target="calc27a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="earnedIn" target="calc27a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="investGate" target="calc27a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="qChildren" target="calc27a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ageTest" target="calc27a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="spouseForm" target="calc27a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="agi" target="calc27a" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
<mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="calc27a" target="eicTable" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

