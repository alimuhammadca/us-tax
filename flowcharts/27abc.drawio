<!-- Form 8862 gate -->
<mxCell id="form8862gate" value="Form 8862 gate&#xa;eicPreviouslyDenied = true?&#xa;→ require Form 8862 Part II&#xa;   (eicEligible = true) to proceed&#xa;→ else emit FORM_8862_EIC_REQUIRED flag" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1"><mxGeometry x="285" y="130" width="240" height="80" as="geometry"/></mxCell>

