<!-- ===== GAPS FIXED ===== -->

<mxCell id="fixed" value="Fixed 2026-04-19:&#xa;G2: childFiledJointReturn — countEicQualifyingChildren() skips child when true (IRC §32(c)(3)(D))&#xa;G3: EIC_QUALIFYING_RELATIONSHIPS set — invalid/blank relationship → child not counted&#xa;G4: Unit test — combat pay election (W-2 box 12Q + 1099-INT to set AGI)&#xa;G5: E2E test — MFJ + qualifying child EIC&#xa;G6: E2E test — combat pay election (with 1099-INT to push AGI into plateau)&#xa;G7: Full-time student path — age 19-23 + isFullTimeStudent=true now counts as qualifying child&#xa;G8: MFS separated-spouse exception — qualifiesForMfsSeparatedSpouseEicException=true uses Single thresholds (IRC §32(d)(2))" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;fontSize=9;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="50" y="910" width="740" height="100" as="geometry"/></mxCell>

<!-- ===== DEFERRED / OOS ===== -->

<mxCell id="deferred" value="Deferred / OOS:&#xa;G1 (LOW): computeInvestmentIncomeForEic() — Schedule E net passive/rental excluded from ceiling test (Schedule E OOS)&#xa;G9 (OOS): Line 27b clergy checkbox — always false until Schedule SE is implemented&#xa;G10 (OOS): Schedule EIC PDF attachment — qualifying child count drives credit; no printable Schedule EIC generated&#xa;G11 (OOS): Schedule C/SE net earnings — excluded from EIC earned income base until SE scope added" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;fontSize=9;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="50" y="1025" width="740" height="75" as="geometry"/></mxCell>

</root></mxGraphModel>
