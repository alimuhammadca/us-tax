<!-- Title -->
<mxCell id="2" value="Form 1040 Lines 27a / 27b / 27c — Earned Income Credit (2025)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="950" height="40" as="geometry"/></mxCell>

