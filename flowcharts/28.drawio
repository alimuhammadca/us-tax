<!-- Part II-A computation -->
<mxCell id="130" value="Part II-A: Earned Income Method&#xa;line16b = $1,700 × numCtcChildren  (ACTC ceiling)&#xa;line17 = min(line16a, line16b)  (potential ACTC)&#xa;line18a = totalWages + combatPayElection&#xa;line19 = max(0, line18a − $2,500)&#xa;line20 = 15% × line19" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="215" y="1120" width="430" height="100" as="geometry"/></mxCell>

