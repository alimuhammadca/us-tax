<!-- Form 8862 required result -->
<mxCell id="25" value="Emit FORM_8862_CTC_REQUIRED&#xa;line14=0, line27=0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="590" y="90" width="200" height="60" as="geometry"/></mxCell>

<!-- Step 1: MAGI -->
<mxCell id="30" value="MAGI = AGI + Form2555 exclusions&#xa;(taxpayer + spouse)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="280" y="200" width="300" height="50" as="geometry"/></mxCell>

<!-- Step 2: Count dependents + tentative credit -->
<mxCell id="40" value="Count numCtcChildren (qualifiesForCTC)&#xa;Count numOdcDependents (qualifiesForODC)&#xa;line5 = $2,000 × numCTC  ✓ (IRS 2025)&#xa;line7 = $500 × numODC&#xa;line8 = line5 + line7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="250" y="270" width="360" height="80" as="geometry"/></mxCell>
<mxCell id="41" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="30" target="40" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

<!-- Phase-out -->
<mxCell id="50" value="Phase-out&#xa;threshold = $400k MFJ | $200k others&#xa;→ stores line9ThresholdAmount (PDF f1_9[0])&#xa;line10 = max(0, MAGI − threshold)  [raw]&#xa;line11 = $50 × ceil(excess/$1,000)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="235" y="370" width="390" height="80" as="geometry"/></mxCell>
