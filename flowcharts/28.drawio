<mxCell id="135" value="Puerto Rico bona fide resident?&#xa;(G11 fixed ✓ — bypasses 3-child gate)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="295" y="1240" width="270" height="80" as="geometry"/></mxCell>
