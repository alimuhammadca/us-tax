<!-- Title -->
<mxCell id="2" value="Form 1040 Line 28 — ACTC / Schedule 8812 (2025)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1"><mxGeometry x="200" y="20" width="600" height="40" as="geometry"/></mxCell>

<!-- INPUTS box -->
<mxCell id="10" value="INPUTS&#xa;AGI (line 11b)&#xa;Filing status&#xa;Dependents (CTC / ODC)&#xa;Form 2555 exclusions&#xa;W-2 box 4 (SS withheld)&#xa;Schedule 2 lines 5/6/13&#xa;Total tax before credits (line 18)&#xa;Schedule 3 prior credits&#xa;EIC pre-set (line 27a)&#xa;AOTC pre-set (line 29)&#xa;ctcScreening / form8862&#xa;ctcScreening.isBonafidePuertoRicoResident" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="20" y="80" width="240" height="220" as="geometry"/></mxCell>

<!-- Form 8862 gate -->
