<!-- Legend -->
<mxCell id="200" value="LEGEND&#xa;Blue = inputs/downstream&#xa;Green = computation steps&#xa;Yellow = decision/gates&#xa;Red = terminal error / zero path&#xa;Orange = warning / partial path&#xa;&#xa;All gaps G1–G24 resolved (2026-04-20)&#xa;G1  QSS threshold — fixed&#xa;G2  Sparse model — fixed (G19)&#xa;G3  PDF fills — fixed (G20)&#xa;G4  Under-24 self-report — deferred&#xa;G5  MFJ spouse-student E2E — fixed&#xa;G6  Form 8862 AOTC E2E — fixed&#xa;G17 YAML field rename — fixed&#xa;G18 hasMagiAddBacks gate — fixed&#xa;G19 student fields + merged loop — fixed&#xa;G20 PDF buildFieldValues — fixed&#xa;G21 unit test boundaries — fixed&#xa;G22/G23/G24 E2E tests — fixed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="700" y="700" width="240" height="320" as="geometry"/></mxCell>

