<!-- Downstream -->
<mxCell id="190" value="Form 1040 line 29 downstream&#xa;line32 = line27a + line28 + line29 + line30 + line31&#xa;line33 = line25d + line26 + line32&#xa;&#xa;Schedule 8812 Part II-B line 24&#xa;reads AOTC pre-set before computeSchedule8812()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="240" y="1760" width="380" height="90" as="geometry"/></mxCell>
