        <mxCell id='e04' value='No' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n04' target='n04b' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
        <mxCell id='e04b' value='Yes' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n04' target='n05' parent='1'><mxGeometry relative='1' as='geometry'/></mxCell>
