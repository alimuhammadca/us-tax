<mxfile host='app.diagrams.net' modified='2026-04-15T00:00:00.000Z' agent='Claude' version='20.8.16' type='device'>
  <diagram id='line5abc-computation' name='Lines 5a/5b/5c Pension and Annuity Flowchart'>
    <mxGraphModel dx='1400' dy='900' grid='1' gridSize='10' guides='1' tooltips='1' connect='1' arrows='1' fold='1' page='1' pageScale='1' pageWidth='1700' pageHeight='3800' math='0' shadow='0'>
      <root>
        <mxCell id='0'/>
        <mxCell id='1' parent='0'/>

        <!-- LEGEND -->
        <mxCell id='leg1' value='Start / End' style='ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;' vertex='1' parent='1'>
