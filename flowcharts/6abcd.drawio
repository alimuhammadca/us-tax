        <!-- STEP 8: Lump-sum check -->
        <mxCell id='n14' value='hasLumpSumBackPaymentForPriorYears == true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='285' y='1630' width='310' height='70' as='geometry'/>
        </mxCell>
        <mxCell id='e14' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n13' target='n14' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- Lump-sum computation (simplified) -->
        <mxCell id='n15' value='computeTaxableSocialSecurityLumpSum() — Pub. 915 Worksheet 3:&#xa;&#xa;lumpSumTotal = sum of lumpSumDetails[].lumpSumAllocatedToPriorYear&#xa;currentYearBase = line6a − lumpSumTotal&#xa;&#xa;// Current-year recompute on reduced base&#xa;currentYearTaxable = computeTaxableSocialSecurityNormal(&#xa;  currentYearBase, worksheetLine3, worksheetLine4,&#xa;  worksheetLine5, worksheetLine6, filingStatus)&#xa;&#xa;// Per-year additional taxable&#xa;for each row in lumpSumDetails:&#xa;  priorSS = row.lumpSumAllocatedToPriorYear&#xa;  priorOther = row.priorYearOtherIncomeForRecompute&#xa;  priorExempt = row.priorYearTaxExemptInterestForRecompute&#xa;  priorAdj = row.priorYearAdjustmentsForRecompute&#xa;  priorPrevTaxable = row.priorYearTaxableBenefitsPreviouslyReported&#xa;  withLump = computeTaxableSocialSecurityNormal(&#xa;    priorSS+priorBenefitsPreviouslyReported, priorOther,&#xa;    priorExempt, 0, priorAdj, filingStatus)&#xa;  withoutLump = priorPrevTaxable (previously reported)&#xa;  additionalTaxable += max(0, withLump − withoutLump)&#xa;&#xa;taxableLumpSum = currentYearTaxable + additionalTaxable&#xa;&#xa;If lumpSumDetails empty → emit non-blocking flag&#xa;SOCIAL_SECURITY_LUMP_SUM_ALLOCATION_REQUIRED' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='760' y='1620' width='310' height='185' as='geometry'/>
        </mxCell>
        <mxCell id='e15' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n14' target='n15' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
          <Array as='points'>
            <mxPoint x='595' y='1665'/>
            <mxPoint x='915' y='1665'/>
          </Array>
        </mxCell>
        <mxCell id='lbl15' value='Yes' style='edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;' vertex='1' connectable='0' parent='e15'>
          <mxGeometry x='-0.1' relative='1' as='geometry'>
            <mxPoint as='offset'/>
          </mxGeometry>
        </mxCell>

