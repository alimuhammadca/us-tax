        </mxCell>

        <!-- Merge line 6b paths -->
        <mxCell id='n19' value='Apply 85% cap:&#xa;if line6a null and line6b null → line6b = 0&#xa;line6b = min(0.85 × line6a, max(0, line6b))' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
