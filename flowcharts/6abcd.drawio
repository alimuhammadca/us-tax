        <!-- ABBREVIATIONS -->
        <mxCell id='abbr' value='Abbreviations&#xa;&#xa;SSA  = Social Security Administration&#xa;RRB  = Railroad Retirement Board&#xa;MFJ  = Married Filing Jointly&#xa;MFS  = Married Filing Separately&#xa;SSI  = Supplemental Security Income&#xa;TIN  = Taxpayer Identification Number&#xa;SSEB = Social Security Equivalent Benefit' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f4ff;strokeColor=#3b5bdb;fontSize=11;align=left;spacingLeft=8;' vertex='1' parent='1'>
          <mxGeometry x='1320' y='450' width='290' height='180' as='geometry'/>
        </mxCell>

        <!-- 2025 CONSTANTS -->
        <mxCell id='const' value='2025 IRS Constants (Verified)&#xa;&#xa;MFJ base amount: $32,000&#xa;MFJ second-tier: $44,000&#xa;All-other base amount: $25,000&#xa;All-other second-tier: $34,000&#xa;Maximum taxable fraction: 85%&#xa;&#xa;MFS + lived with spouse:&#xa;  No base amount; use 85% path&#xa;&#xa;Sources: IRS i1040gi_2025,&#xa;Pub. 915 (2025)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;align=left;spacingLeft=8;' vertex='1' parent='1'>
          <mxGeometry x='1320' y='650' width='290' height='210' as='geometry'/>
        </mxCell>

        <!-- KNOWN GAPS -->
        <mxCell id='gaps' value='Implementation Status (2026-04-16)&#xa;&#xa;✓ Gap 1 resolved: Worksheet line 5 wired for&#xa;  Form 2555 exclusions (taxpayer + spouse).&#xa;  Deferred: Form 8839 adoption (§137),&#xa;  Form 8815, Samoa/PR exclusions.&#xa;&#xa;✓ Gap 2 resolved: Lump-sum uses full&#xa;  Pub. 915 Worksheet 3 per-year recompute.&#xa;&#xa;✓ Gap 3 resolved: Worksheet line 6 auto-pulled&#xa;  from Schedule 1 Part II adjustments&#xa;  (incomeAdjustments.line10FromSchedule1Line26).&#xa;&#xa;✓ Gap 4 resolved: Line 6c &amp; 6d checkboxes&#xa;  mapped in f1040_field_mapping_semantic.csv.&#xa;&#xa;✓ Gap 5 resolved: Negative net benefits emits&#xa;  SOCIAL_SECURITY_NEGATIVE_NET_BENEFITS_MANUAL_REVIEW&#xa;  (non-blocking); SS lines omitted from output.&#xa;  IRA coordination emits advisory flag;&#xa;  iterative Pub. 590-A solve still deferred.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;' vertex='1' parent='1'>
