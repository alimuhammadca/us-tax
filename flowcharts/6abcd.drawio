        <!-- STEP 1: Gate hadSocialSecurityBenefits -->
        <mxCell id='n02' value='taxpayerHadBenefits == true&#xa;OR spouseHadBenefits == true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;' vertex='1' parent='1'>
