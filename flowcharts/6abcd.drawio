        <!-- Normal path -->
        <mxCell id='n18' value='line6b = taxableNormal&#xa;line6c = false' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
