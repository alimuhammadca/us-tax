        <!-- STEP 3: Compute gross benefits per person -->
        <mxCell id='n06' value='computeSocialSecurityForPerson() × 2&#xa;&#xa;For each SSA-1099 entry:&#xa;  TIN match via beneficiarySSN → grossBenefits += netBenefitsAmount&#xa;For each RRB-1099 entry:&#xa;  TIN match via recipientIdNumber → grossBenefits += netSSEBAmount&#xa;&#xa;If hasSupplementalSecurityIncome:&#xa;  grossBenefits -= supplementalSecurityIncomeAmount  (SSI excluded)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='235' y='450' width='410' height='120' as='geometry'/>
        </mxCell>
        <mxCell id='e05' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n04' target='n06' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- STEP 4: line6a -->
        <mxCell id='n07' value='line6a = taxpayer.grossBenefits + spouse.grossBenefits' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='270' y='630' width='340' height='46' as='geometry'/>
        </mxCell>
        <mxCell id='e06' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n06' target='n07' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- STEP 5: Line 6d determination -->
        <mxCell id='n08' value='isMfs = filingStatus == MFS?&#xa;livedApartAllYear?&#xa;&#xa;line6d = isMfs &amp;&amp; livedApartAllYear' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='270' y='730' width='340' height='70' as='geometry'/>
        </mxCell>
        <mxCell id='e07' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n07' target='n08' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- STEP 6: Build worksheet inputs -->
        <mxCell id='n09' value='Build Worksheet Inputs:&#xa;&#xa;w1 = line6a&#xa;worksheetLine3 = line1z+2b+3b+4b+5b+7a+8 (or manual override)&#xa;worksheetLine4 = line2a tax-exempt interest (or override)&#xa;worksheetLine5 = Form2555 taxpayer lines 45+50&#xa;              + Form2555 spouse lines 45+50&#xa;              (⚠ Form 8839/8815/Samoa/PR deferred)&#xa;worksheetLine6 = incomeAdjustments.line10FromSchedule1Line26()' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='215' y='860' width='450' height='130' as='geometry'/>
        </mxCell>
        <mxCell id='e08' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n08' target='n09' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- STEP 7: MFS branch decision -->
        <mxCell id='n10' value='MFS + livedWithSpouseAnyTime == true?' style='rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='280' y='1050' width='320' height='70' as='geometry'/>
        </mxCell>
        <mxCell id='e09' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n09' target='n10' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- MFS restrictive branch -->
        <mxCell id='n11' value='MFS + Lived-With-Spouse Branch:&#xa;&#xa;w2 = 0.50 × w1&#xa;w5 = w2 + worksheetLine3 + worksheetLine4&#xa;w7 = max(0, w5 - worksheetLine6)&#xa;&#xa;taxableNormal = min(0.85 × w1, 0.85 × w7)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='760' y='1040' width='290' height='110' as='geometry'/>
        </mxCell>
        <mxCell id='e10' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n10' target='n11' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
          <Array as='points'>
            <mxPoint x='600' y='1085'/>
            <mxPoint x='905' y='1085'/>
          </Array>
        </mxCell>
        <mxCell id='lbl10' value='Yes' style='edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;' vertex='1' connectable='0' parent='e10'>
          <mxGeometry x='-0.1' relative='1' as='geometry'>
            <mxPoint as='offset'/>
          </mxGeometry>
        </mxCell>

        <!-- Normal branch: threshold calculation -->
        <mxCell id='n12' value='Normal / MFJ / MFS-apart Branch:&#xa;&#xa;w2 = 0.50 × w1&#xa;w5 = w2 + worksheetLine3 + worksheetLine4&#xa;w7 = max(0, w5 - worksheetLine6)&#xa;&#xa;if w7 ≤ 0: taxableNormal = 0&#xa;&#xa;baseAmount = $32,000 (MFJ) | $25,000 (other)&#xa;secondBase = $44,000 (MFJ) | $34,000 (other)&#xa;overBase = max(0, w7 - baseAmount)&#xa;if overBase ≤ 0: taxableNormal = 0&#xa;&#xa;taxableUpTo50 = min(0.5×w1, 0.5×overBase)&#xa;overSecond = max(0, w7 - secondBase)&#xa;if overSecond &gt; 0:&#xa;  plateau = min(0.5×(secondBase-baseAmount), 0.5×w1)&#xa;  taxable = plateau + 0.85×overSecond&#xa;else:&#xa;  taxable = taxableUpTo50&#xa;&#xa;taxableNormal = min(0.85×w1, taxable)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='195' y='1180' width='490' height='290' as='geometry'/>
        </mxCell>
        <mxCell id='e11' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n10' target='n12' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>
        <mxCell id='lbl11' value='No' style='edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;' vertex='1' connectable='0' parent='e11'>
          <mxGeometry x='-0.1' relative='1' as='geometry'>
            <mxPoint as='offset'/>
          </mxGeometry>
        </mxCell>

        <!-- Merge normal branches -->
        <mxCell id='n13' value='taxableNormal determined' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='300' y='1535' width='280' height='40' as='geometry'/>
