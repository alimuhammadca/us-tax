        </mxCell>
        <mxCell id='e15' value='Yes' style='edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;' edge='1' source='n15' target='n16' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- Merge line 7a -->
        <mxCell id='n17' value='Compute line7a&#xa;&#xa;line7a = line7aBase + (childAmount if includesChildCapitalGainLoss)&#xa;&#xa;includesChildCapitalGainLoss from Form 8814 line 10&#xa;(pre-computed before this function is called)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
          <mxGeometry x='310' y='1720' width='420' height='80' as='geometry'/>
