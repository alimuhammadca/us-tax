        <!-- Finalize line 7b -->
        <mxCell id='n18' value='Finalize line 7b checkboxes&#xa;&#xa;line7bScheduleDNotRequired = exception1&#xa;line7bIncludesChildCapitalGainLoss = includesChildCapitalGainLoss&#xa;line7bChildAmountFromForm8814Line10 = childAmount' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;' vertex='1' parent='1'>
