  <diagram id='line7ab-computation' name='Lines 7a/7b Capital Gain or (Loss) Flowchart'>
    <mxGraphModel dx='1400' dy='900' grid='1' gridSize='10' guides='1' tooltips='1' connect='1' arrows='1' fold='1' page='1' pageScale='1' pageWidth='1900' pageHeight='4000' math='0' shadow='0'>
