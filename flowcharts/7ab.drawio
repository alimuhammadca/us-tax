        <!-- Form 8997 — now produced as required attachment -->
        <mxCell id='gap2' value='✓ Form 8997 (QOF Annual Report)&#xa;produced as required-attachment flag&#xa;when taxpayer OR spouse QOF deferral&#xa;detected. Full computation deferred.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;' vertex='1' parent='1'>
          <mxGeometry x='760' y='1045' width='260' height='70' as='geometry'/>
