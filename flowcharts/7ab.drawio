        </mxCell>
        <mxCell id='e20' value='No' style='edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;' edge='1' source='n19' target='n20' parent='1'>
          <mxGeometry relative='1' as='geometry'/>
        </mxCell>

        <!-- OUTPUT -->
        <mxCell id='n21' value='Return CapitalGainLossComputation&#xa;&#xa;→ form1040.income.capitalGainLoss = line7a&#xa;→ form1040.income.line7bScheduleDNotRequired&#xa;→ form1040.income.line7bIncludesChildCapitalGainLoss&#xa;→ form1040.income.line7bChildAmountFromForm8814Line10&#xa;→ TaxReturnComputation.scheduleD (if required)&#xa;→ TaxReturnComputation.form8949 (if required)' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;' vertex='1' parent='1'>
