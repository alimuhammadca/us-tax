        <mxCell id='gap1' value='&#x2713; IMPLEMENTED: 1099-K top entry space&#xa;form1099KPersonalItemsDisclosureAmount field&#xa;in both personal forms + output model.&#xa;Disclosure only — no effect on line 9 or 10.' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;' vertex='1' parent='1'>
