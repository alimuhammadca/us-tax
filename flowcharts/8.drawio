        </mxCell>

        <!-- END -->
        <mxCell id='n19' value='END&#xa;&#xa;line 8 (otherIncomeSchedule1) feeds:&#xa;&#x2022; line 9 total income (computeTotalIncome)&#xa;&#x2022; AGI (lines 11a / 11b)&#xa;&#x2022; AMT (Form 6251 line 2b: negative of taxable state/local refund)&#xa;&#x2022; PDF export — Schedule 1 Part I fields' style='ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;' vertex='1' parent='1'>
          <mxGeometry x='290' y='3075' width='440' height='100' as='geometry'/>
        </mxCell>
        <mxCell id='e19' style='edgeStyle=orthogonalEdgeStyle;' edge='1' source='n18' target='n19' parent='1'>
